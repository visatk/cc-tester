
{
  "name": "cc-tester",
  "version": "1.0.0",
  "description": "Zero-dependency, edge-ready credit card testing utility",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "worker": "./dist/index.js",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "keywords": [
    "credit-card",
    "testing",
    "stripe",
    "cloudflare-workers",
    "luhn"
  ],
  "author": "SaaS Foundry",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "tsup": "^8.2.3",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
